# ==========================================
# 校园个人博客系统 - 后端环境变量配置
# 复制此文件为 .env 并填入实际值
# ==========================================

# Flask密钥（生产环境请使用随机字符串）
SECRET_KEY=your-secret-key-change-in-production

# 调试模式（生产部署设为 False）
DEBUG=True

# Supabase项目URL（在Supabase控制台 → Settings → API 获取）
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon key（公开密钥，前端使用）
SUPABASE_KEY=eyJhbGciOiJIUzI1...

# Supabase service_role key（服务端密钥，仅后端使用，保密！）
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1...

# JWT签名密钥（Supabase Dashboard → Settings → API → JWT Settings → JWT Secret）
# 注意：这不是anon key！是JWT Settings里的JWT Secret
JWT_SECRET=your-supabase-jwt-secret

# 允许的跨域来源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000

# 服务端口
PORT=5000
